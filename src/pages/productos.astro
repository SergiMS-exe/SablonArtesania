---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ItemCard from "../components/ItemCard";
import ModalCarousel from "../components/ModalCarousel";
import Title from "../components/Title.astro";
import products from "../data/products.json";

// Filtros por material
const categoryOrder = ["cuero", "hilo"] as const;
const categoryLabels: Record<string, string> = {
  cuero: "Cuero",
  hilo: "Hilo",
};
const activeCategories = categoryOrder.filter((c) =>
  products.some((p) => p.category === c)
);
const allCategories = [
  { id: "all", label: "Todos" },
  ...activeCategories.map((c) => ({ id: c, label: categoryLabels[c] })),
];
---

<html lang="es">
  <head>
    <BaseHead title="Productos" description="Nuestros productos artesanales" />
  </head>
  <body class="bg-surface-low">
    <main>
      <Header />

      <section class="max-w-6xl mx-auto pt-13 pb-8 px-6 text-center">
        <Title title="Nuestros Productos">
          Descubre nuestra selección de productos artesanales hechos a mano con
          dedicación y pasión. Cada pieza refleja la tradición y el arte de la
          artesanía asturiana.
        </Title>
      </section>

      <!-- Filtro por material -->
      <div class="max-w-screen-xl mx-auto px-4 md:px-8 lg:px-12 mb-8">
        <div class="flex flex-wrap gap-2 justify-center">
          {allCategories.map((cat) => (
            <button
              data-filter={cat.id}
              class:list={[
                "filter-btn px-5 py-2 rounded-full text-sm font-medium transition-colors duration-200 border border-leather/20 text-dark-brown/70 hover:border-leather hover:text-leather",
                cat.id === "all" ? "active-filter" : "",
              ]}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Grid de productos -->
      <div
        id="products-grid"
        class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 p-4 md:px-8 lg:px-12"
      >
        {products.map((producto) => (
          <div data-category={producto.category} class="product-wrapper">
            <ItemCard {...producto} client:load />
          </div>
        ))}
      </div>

      <ModalCarousel client:only="react" />

      <Footer />
    </main>
  </body>
</html>

<style>
  .filter-btn.active-filter {
    background-color: rgb(93 64 55);
    border-color: rgb(93 64 55);
    color: rgb(250 243 224);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const wrappers = document.querySelectorAll<HTMLElement>(".product-wrapper");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.filter!;

        filterBtns.forEach((b) => b.classList.remove("active-filter"));
        btn.classList.add("active-filter");

        wrappers.forEach((wrapper) => {
          wrapper.style.display =
            cat === "all" || wrapper.dataset.category === cat ? "" : "none";
        });
      });
    });
  });
</script>
