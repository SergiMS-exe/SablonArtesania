---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ItemCard from "../components/ItemCard";
import ModalCarousel from "../components/ModalCarousel";
import Title from "../components/Title.astro";
import products from "../data/products.json";

// Categorías de material: las activas se derivan de los productos, las "coming soon" se añaden manualmente
const activeCategories = [...new Set(products.map((p) => p.category))];
const allCategories = [
  { id: "all", label: "Todos", comingSoon: false },
  { id: "cuero", label: "Cuero", comingSoon: false },
  { id: "fieltro", label: "Fieltro", comingSoon: !activeCategories.includes("fieltro") },
  { id: "madera", label: "Madera", comingSoon: !activeCategories.includes("madera") },
];
---

<html lang="es">
  <head>
    <BaseHead title="Productos" description="Nuestros productos artesanales" />
  </head>
  <body class="bg-surface-low">
    <main>
      <Header />

      <section class="max-w-6xl mx-auto pt-13 pb-8 px-6 text-center">
        <Title title="Nuestros Productos">
          Descubre nuestra selección de productos artesanales hechos a mano con
          dedicación y pasión. Cada pieza refleja la tradición y el arte de la
          artesanía asturiana.
        </Title>
      </section>

      <!-- Filtro por material -->
      <div class="max-w-screen-xl mx-auto px-4 md:px-8 lg:px-12 mb-8">
        <div class="flex flex-wrap gap-2 justify-center">
          {allCategories.map((cat) => (
            <button
              data-filter={cat.id}
              class:list={[
                "filter-btn px-5 py-2 rounded-full text-sm font-medium transition-colors duration-200 border",
                cat.comingSoon
                  ? "border-dark-brown/15 text-dark-brown/35 cursor-default"
                  : "border-leather/20 text-dark-brown/70 hover:border-leather hover:text-leather",
                cat.id === "all" ? "active-filter" : "",
              ]}
              disabled={cat.comingSoon}
              title={cat.comingSoon ? "Próximamente" : undefined}
            >
              {cat.label}
              {cat.comingSoon && (
                <span class="ml-1.5 text-xs opacity-60 font-normal">Próx.</span>
              )}
            </button>
          ))}
        </div>
      </div>

      <!-- Aviso material sin productos -->
      <div
        id="coming-soon-notice"
        class="hidden max-w-screen-xl mx-auto px-4 md:px-8 lg:px-12 mb-8"
      >
        <div class="bg-cream rounded-2xl border border-leather/15 p-12 text-center">
          <div class="w-12 h-12 bg-leather/10 rounded-xl flex items-center justify-center mx-auto mb-4 text-leather">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3 class="text-xl font-title font-bold text-walnut-deep mb-2" id="coming-soon-title">Próximamente</h3>
          <p class="text-dark-brown/60 text-sm max-w-md mx-auto" id="coming-soon-text">
            Estamos trabajando en esta colección. Muy pronto disponible.
          </p>
        </div>
      </div>

      <!-- Grid de productos -->
      <div
        id="products-grid"
        class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 p-4 md:px-8 lg:px-12"
      >
        {products.map((producto) => (
          <div data-category={producto.category} class="product-wrapper">
            <ItemCard {...producto} client:load />
          </div>
        ))}
      </div>

      <ModalCarousel client:only="react" />

      <Footer />
    </main>
  </body>
</html>

<style>
  .filter-btn.active-filter {
    background-color: rgb(93 64 55);
    border-color: rgb(93 64 55);
    color: rgb(250 243 224);
  }
</style>

<script>
  const comingSoonLabels: Record<string, { title: string; text: string }> = {
    madera: {
      title: "Colección de Madera — Próximamente",
      text: "Estamos trabajando en nuestra colección de artesanía en madera. Muy pronto disponible.",
    },
    fieltro: {
      title: "Colección de Fieltro — Próximamente",
      text: "Pronto incorporaremos piezas de fieltro de nuestros artesanos amigos.",
    },
  };

  document.addEventListener("DOMContentLoaded", () => {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn:not([disabled])");
    const wrappers = document.querySelectorAll<HTMLElement>(".product-wrapper");
    const comingSoonNotice = document.getElementById("coming-soon-notice");
    const comingSoonTitle = document.getElementById("coming-soon-title");
    const comingSoonText = document.getElementById("coming-soon-text");
    const productsGrid = document.getElementById("products-grid");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.filter!;

        filterBtns.forEach((b) => b.classList.remove("active-filter"));
        btn.classList.add("active-filter");

        // Filtro sin productos => mostrar aviso coming soon
        const hasProducts = cat === "all" || [...wrappers].some((w) => w.dataset.category === cat);
        if (!hasProducts && comingSoonLabels[cat]) {
          comingSoonNotice?.classList.remove("hidden");
          if (productsGrid) productsGrid.style.display = "none";
          if (comingSoonTitle) comingSoonTitle.textContent = comingSoonLabels[cat].title;
          if (comingSoonText) comingSoonText.textContent = comingSoonLabels[cat].text;
          return;
        }

        comingSoonNotice?.classList.add("hidden");
        if (productsGrid) productsGrid.style.display = "";

        wrappers.forEach((wrapper) => {
          wrapper.style.display =
            cat === "all" || wrapper.dataset.category === cat ? "" : "none";
        });
      });
    });
  });
</script>
