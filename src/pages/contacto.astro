---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Title from "../components/Title.astro";

const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "";
---

<html lang="es">
    <head>
        <BaseHead
            title="Contacto - El Sablón"
            description="Ponte en contacto con nosotros"
        />
    </head>
    <body class="bg-surface-low">
        <main>
            <Header />

            <section class="max-w-4xl mx-auto py-16 px-6">
                <div class="text-center mb-12">
                    <Title title="Contacta con Nosotros">
                        ¿Te interesa alguna de nuestras piezas? ¿Quieres hacer
                        un encargo personalizado? Rellena el formulario y nos
                        pondremos en contacto contigo lo antes posible.
                    </Title>
                </div>

                <div class="grid md:grid-cols-2 gap-8">
                    <!-- Formulario -->
                    <div class="bg-cream p-8 rounded-2xl shadow">
                        <form id="contactForm" class="space-y-5" data-endpoint={contactEndpoint}>
                            <div>
                                <label
                                    for="nombre"
                                    class="block text-sm font-semibold text-walnut-deep mb-2"
                                >
                                    Nombre completo *
                                </label>
                                <input
                                    type="text"
                                    id="nombre"
                                    name="nombre"
                                    required
                                    class="w-full px-4 py-3 rounded-xl border border-wood-light bg-surface-low focus:border-leather focus:outline-none transition-colors text-sm"
                                    placeholder="Tu nombre"
                                />
                            </div>

                            <div>
                                <label
                                    for="email"
                                    class="block text-sm font-semibold text-walnut-deep mb-2"
                                >
                                    Email *
                                </label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full px-4 py-3 rounded-xl border border-wood-light bg-surface-low focus:border-leather focus:outline-none transition-colors text-sm"
                                    placeholder="tu@email.com"
                                />
                            </div>

                            <div>
                                <label
                                    for="telefono"
                                    class="block text-sm font-semibold text-walnut-deep mb-2"
                                >
                                    Teléfono
                                </label>
                                <input
                                    type="tel"
                                    id="telefono"
                                    name="telefono"
                                    class="w-full px-4 py-3 rounded-xl border border-wood-light bg-surface-low focus:border-leather focus:outline-none transition-colors text-sm"
                                    placeholder="600 123 456"
                                />
                            </div>

                            <div>
                                <label
                                    for="asunto"
                                    class="block text-sm font-semibold text-walnut-deep mb-2"
                                >
                                    Asunto *
                                </label>
                                <select
                                    id="asunto"
                                    name="asunto"
                                    required
                                    class="w-full px-4 py-3 rounded-xl border border-wood-light bg-surface-low focus:border-leather focus:outline-none transition-colors text-sm"
                                >
                                    <option value="">Selecciona un asunto</option>
                                    <option value="consulta-producto">Consulta sobre producto</option>
                                    <option value="encargo-personalizado">Encargo personalizado</option>
                                    <option value="taller">Reserva de taller</option>
                                    <option value="otro">Otro</option>
                                </select>
                            </div>

                            <div>
                                <label
                                    for="mensaje"
                                    class="block text-sm font-semibold text-walnut-deep mb-2"
                                >
                                    Mensaje *
                                </label>
                                <textarea
                                    id="mensaje"
                                    name="mensaje"
                                    required
                                    rows="5"
                                    class="w-full px-4 py-3 rounded-xl border border-wood-light bg-surface-low focus:border-leather focus:outline-none transition-colors resize-none text-sm"
                                    placeholder="Cuéntanos en qué podemos ayudarte..."
                                ></textarea>
                            </div>

                            <button
                                type="submit"
                                class="w-full bg-leather hover:bg-walnut-deep text-cream py-3 rounded-full font-semibold transition-colors duration-200"
                            >
                                Enviar Mensaje
                            </button>

                            <div
                                id="formMessage"
                                class="hidden p-4 rounded-xl text-center font-semibold text-sm"
                            >
                            </div>
                        </form>
                    </div>

                    <!-- Información de contacto -->
                    <div class="space-y-5">
                        <!-- Redes sociales -->
                        <div class="bg-cream p-8 rounded-2xl shadow">
                            <h3 class="text-xl font-title font-bold text-walnut-deep mb-5">
                                Otras formas de contacto
                            </h3>

                            <div class="space-y-3">
                                <a
                                    href="https://www.facebook.com/profile.php?id=61560506500874"
                                    target="_blank"
                                    class="flex items-center gap-4 p-4 bg-surface-low rounded-xl hover:bg-surface-container transition-colors group"
                                >
                                    <div class="w-10 h-10 bg-leather/10 rounded-xl flex items-center justify-center text-leather group-hover:bg-leather/15 transition-colors flex-shrink-0">
                                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-walnut-deep text-sm">Facebook</p>
                                        <p class="text-xs text-dark-brown/60">El Sablón Artesanía</p>
                                    </div>
                                </a>

                                <a
                                    href="https://www.instagram.com/elsablonartesania"
                                    target="_blank"
                                    class="flex items-center gap-4 p-4 bg-surface-low rounded-xl hover:bg-surface-container transition-colors group"
                                >
                                    <div class="w-10 h-10 bg-leather/10 rounded-xl flex items-center justify-center text-leather group-hover:bg-leather/15 transition-colors flex-shrink-0">
                                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-walnut-deep text-sm">Instagram</p>
                                        <p class="text-xs text-dark-brown/60">@elsablonartesania</p>
                                    </div>
                                </a>
                            </div>
                        </div>

                        <!-- Encuéntranos -->
                        <div class="bg-cream p-8 rounded-2xl shadow">
                            <h3 class="text-xl font-title font-bold text-walnut-deep mb-5">
                                Encuéntranos
                            </h3>

                            <div class="space-y-4 text-dark-brown/70">
                                <div class="flex items-start gap-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-leather flex-shrink-0 mt-0.5">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                        <circle cx="12" cy="10" r="3"/>
                                    </svg>
                                    <div>
                                        <p class="font-semibold text-walnut-deep text-sm">Oviñana</p>
                                        <p class="text-xs">Plaza principal — Mercado mensual</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-leather flex-shrink-0 mt-0.5">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                        <circle cx="12" cy="10" r="3"/>
                                    </svg>
                                    <div>
                                        <p class="font-semibold text-walnut-deep text-sm">Somao</p>
                                        <p class="text-xs">Plaza principal — Mercado mensual</p>
                                    </div>
                                </div>
                            </div>

                            <a
                                href="/encuentranos"
                                class="mt-5 block text-center bg-surface-low hover:bg-surface-container text-leather font-semibold py-3 rounded-full transition-colors duration-200 text-sm"
                            >
                                Ver ubicaciones
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <Footer />
        </main>

        <script>
            const form = document.getElementById("contactForm") as HTMLFormElement;
            const formMessage = document.getElementById("formMessage") as HTMLDivElement;
            const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
            const endpoint = form.dataset.endpoint?.trim();

            const showMessage = (text: string, kind: "ok" | "err") => {
                formMessage.textContent = text;
                formMessage.className =
                    "p-4 rounded-xl text-center font-semibold text-sm " +
                    (kind === "ok"
                        ? "bg-green-100 text-green-800"
                        : "bg-red-100 text-red-800");
                formMessage.classList.remove("hidden");
            };

            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                if (!endpoint) {
                    showMessage(
                        "El formulario aún no está configurado. Escríbenos por Instagram o Facebook mientras tanto.",
                        "err"
                    );
                    return;
                }

                const payload = Object.fromEntries(new FormData(form).entries());

                submitBtn.disabled = true;
                submitBtn.textContent = "Enviando…";

                try {
                    const res = await fetch(endpoint, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            ...payload,
                            origin: "sablon-artesania-web",
                            submittedAt: new Date().toISOString(),
                        }),
                    });

                    if (!res.ok) throw new Error(`HTTP ${res.status}`);

                    showMessage(
                        "¡Mensaje enviado! Nos pondremos en contacto contigo pronto.",
                        "ok"
                    );
                    form.reset();
                    setTimeout(() => formMessage.classList.add("hidden"), 5000);
                } catch (err) {
                    showMessage(
                        "No hemos podido enviar el mensaje. Inténtalo de nuevo en un rato.",
                        "err"
                    );
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = "Enviar Mensaje";
                }
            });
        </script>
    </body>
</html>
