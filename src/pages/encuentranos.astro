---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HabitualMarketCard from "../components/HabitualMarketCard.astro";
import MarketsCalendar from "../components/MarketsCalendar.astro";
import Title from "../components/Title.astro";
---

<html lang="es">
    <head>
        <BaseHead
            title="Dónde Encontrarnos - El Sablón"
            description="Próximos mercados artesanales en Asturias donde podrás encontrarnos"
        />
    </head>
    <body class="bg-surface-low">
        <main>
            <Header />

            <section class="max-w-6xl mx-auto pt-16 pb-8 px-6 text-center">
                <Title title="Dónde Encontrarnos">
                    Solemos acudir a mercados artesanales por Asturias. Las
                    fechas pueden variar, así que aquí abajo te dejamos las
                    próximas salidas confirmadas. ¡Ven a vernos!
                </Title>
            </section>

            <section class="max-w-6xl mx-auto px-6 mb-12">
                <MarketsCalendar />
            </section>

            <section class="max-w-6xl mx-auto px-6 mb-12">
                <div class="text-center mb-8">
                    <h2 class="text-3xl md:text-4xl font-title font-bold text-walnut-deep mb-3">
                        Nuestros mercados habituales
                    </h2>
                    <p class="text-dark-brown/70 max-w-2xl mx-auto">
                        Aunque no siempre podemos acudir, estos son los dos mercados
                        en los que solemos estar a lo largo del año.
                    </p>
                </div>

                <div class="grid md:grid-cols-2 gap-7">
                    <HabitualMarketCard
                        name="Oviñana"
                        subtitle="Mercado mensual artesanal"
                        color="terra-cotta"
                        image="/plaza_ovinana.webp"
                        imageAlt="Plaza de Oviñana"
                        locationLabel="Plaza principal de Oviñana"
                        description="Ambiente familiar con productos locales y vistas a la costa asturiana."
                        mapsUrl="https://www.google.com/maps/place/Plaza+de+Oviñana,+33156+Oviñana,+Asturias"
                        embedSrc="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2922.393314583816!2d-6.237123684528927!3d43.56922197912327!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd36f7e7e6b2b8e1%3A0x7e2e6e6e6e6e6e6e!2sPlaza%20de%20Ovi%C3%B1ana%2C%2033156%20Ovi%C3%B1ana%2C%20Asturias!5e0!3m2!1ses!2ses!4v1686754321000!5m2!1ses!2ses"
                    />
                    <HabitualMarketCard
                        name="Somao"
                        subtitle="Mercado mensual artesanal"
                        color="moss-green"
                        image="/plaza_somao.webp"
                        imageAlt="Plaza de Somao"
                        locationLabel="Plaza principal de Somao"
                        description="Pueblo Ejemplar de Asturias, con artesanos, productos locales y música en directo."
                        mapsUrl="https://www.google.com/maps/place/Somao,+33139,+Asturias"
                        embedSrc="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2923.036457769463!2d-6.181370684529326!3d43.5816249791227!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd36f7e2b7e6b8e1%3A0x7e2e6e6e6e6e6e6e!2sSomao%2C%2033139%20Pravia%2C%20Asturias!5e0!3m2!1ses!2ses!4v1686754321001!5m2!1ses!2ses"
                    />
                </div>
            </section>

            <section class="max-w-4xl mx-auto px-6 mb-16">
                <div class="bg-leather text-cream p-10 md:p-12 rounded-2xl text-center">
                    <h2 class="text-3xl font-title font-bold mb-3">
                        ¿No puedes venir al mercado?
                    </h2>
                    <p class="text-lg mb-7 text-cream/85 max-w-xl mx-auto">
                        Contacta con nosotros para o consultar disponibilidad de productos.
                    </p>
                    <a
                        href="/contacto"
                        class="inline-block bg-cream text-leather px-8 py-3 rounded-full font-semibold hover:bg-wood-light transition-colors duration-200"
                    >
                        Contáctanos
                    </a>
                </div>
            </section>

            <Footer />
        </main>
    </body>
</html>
